# BB Frontend environment variables
#
# Copy this file to `.env.local` for development.
# Set the same vars in your Vercel project dashboard for production.
#
# There are currently NO required env vars — the app uses mocked data.
# Add keys below as you wire real integrations.

# --- App ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API ---
# NEXT_PUBLIC_API_BASE_URL=
# API_SECRET=

# --- Auth (e.g. Clerk / NextAuth / Supabase) ---
# NEXT_PUBLIC_AUTH_PROVIDER=
# AUTH_SECRET=

# --- Integrations ---
# META_ADS_APP_ID=
# META_ADS_APP_SECRET=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GA4_SERVICE_ACCOUNT_JSON=
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# --- Observability ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Output mode (optional; for self-hosting) ---
# Set to `standalone` to produce a minimal deploy artifact under `.next/standalone`.
# NEXT_OUTPUT=
